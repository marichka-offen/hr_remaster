{
    "extends": "astro/tsconfigs/strict",
    "include": [
        ".astro/types.d.ts",
        "**/*"
    ],
    "exclude": [
        "dist"
    ],
    "compilerOptions": {
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "baseUrl": ".",
        "paths": {
            "@components/*": [
                "src/components/*"
            ],
            "@layouts/*": [
                "src/layouts/*"
            ],
            "@hooks/*": [
                "src/hooks/*"
            ],
            "@lib/*": [
                "src/lib/*"
            ],
            "@tokens/*": [
                "src/design-tokens/*"
            ],
            "@types/*": [
                "src/types/*"
            ]
        }
    }
}