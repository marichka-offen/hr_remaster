---
import SiteLayout from '@layouts/SiteLayout.astro'
import PageSections from '@components/sections/PageSections/PageSections.astro'
import { sanityClient } from '@lib/sanity/client'
import { booksPageQuery } from '@lib/sanity/queries'

const pageData = await sanityClient.fetch(booksPageQuery)

const sections = pageData?.sections ?? []
const pageTitle = pageData?.title ?? 'Books'
const pageDescription = pageData?.description ?? ''
---

<SiteLayout title={pageTitle} description={pageDescription}>
    <main id="main">
        <PageSections sections={sections} />
        <section class="books-page">
            <div class="books-page__container">
                <p>Books listing — coming soon</p>
            </div>
        </section>
    </main>
</SiteLayout>

<style lang="scss">
    .books-page {
        background: var(--parchment);

        &__container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 80px 24px 80px;

            @media (max-width: 768px) {
                padding: 56px 20px;
            }
        }
    }
</style>
