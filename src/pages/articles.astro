---
import SiteLayout from '@layouts/SiteLayout.astro'
import PageSections from '@components/sections/PageSections/PageSections.astro'
import ArticleCardGrid from '@components/composite/ArticleCardGrid/ArticleCardGrid'
import SectionHeader from '@components/composite/SectionHeader/SectionHeader.astro'
import { sanityClient } from '@lib/sanity/client'
import { articlesPageQuery, allArticlesQuery } from '@lib/sanity/queries'

const pageData = await sanityClient.fetch(articlesPageQuery)
const articles = await sanityClient.fetch(allArticlesQuery)

const sections = pageData?.sections ?? []
const pageTitle = pageData?.title ?? 'Articles'
const pageDescription = pageData?.description ?? ''
---

<SiteLayout title={pageTitle} description={pageDescription}>
    <main id='main'>
        <PageSections sections={sections} articles={articles} />
        <section class='articles-page'>
            <div class='articles-page__container'>
                <div class='articles-page__header'>
                    <SectionHeader label='Archive' heading='All Articles' align='center' />
                </div>
                <ArticleCardGrid
                    articles={articles}
                    showCategoryFilter={true}
                    client:load
                />
            </div>
        </section>
    </main>
</SiteLayout>

<style lang='scss'>
    .articles-page {
        background: var(--parchment);

        &__container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 120px 24px 80px;

            @media (max-width: 768px) {
                padding: 56px 20px;
            }
        }

        &__header {
            text-align: center;
            margin-bottom: 56px;
        }
    }
</style>
