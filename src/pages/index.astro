---
import SiteLayout from '@layouts/SiteLayout.astro'
import HomeHero from '@components/HomeHero/HomeHero.astro'
import FeaturedArticle from '@components/FeaturedArticle/FeaturedArticle.astro'
import ArticlesSection from '@components/ArticlesSection/ArticlesSection.astro'
import AboutPreview from '@components/AboutPreview/AboutPreview.astro'
import BookPreview from '@components/BookPreview/BookPreview.astro'
import { sanityClient } from '@lib/sanity/client'
import { pageBySlugQuery, allArticlesQuery } from '@lib/sanity/queries'
import type { ArticleMeta } from '@app-types/article'

const pageData = await sanityClient.fetch(pageBySlugQuery, { slug: 'home' })
const articles: ArticleMeta[] = await sanityClient.fetch(allArticlesQuery)

const sections = pageData?.sections ?? []
const pageTitle = pageData?.title ?? 'History Reconsidered'
const pageDescription = pageData?.description ?? ''
---

<SiteLayout title={pageTitle} description={pageDescription}>
    <main id="main">
        {sections.map((section: any) => {
            switch (section._type) {
                case 'heroSection':
                    return (
                        <HomeHero
                            label={section.label}
                            title={section.title}
                            quote={section.quote}
                            quoteAuthor={section.quoteAuthor}
                            ctaText={section.ctaText}
                            ctaLink={section.ctaLink}
                        />
                    )
                case 'featuredArticleSection':
                    return section.article ? (
                        <FeaturedArticle
                            label={section.label}
                            heading={section.heading}
                            article={section.article}
                        />
                    ) : null
                case 'articlesGridSection':
                    return (
                        <ArticlesSection
                            articles={section.articles?.length ? section.articles : articles}
                            label={section.label}
                            heading={section.heading}
                            showCategoryFilter={section.showCategoryFilter}
                            ctaText={section.cta?.text}
                            ctaLink={section.cta?.link}
                            ctaNewTab={section.cta?.openInNewTab}
                        />
                    )
                case 'aboutPreviewSection':
                    return (
                        <AboutPreview
                            name={section.name}
                            role={section.role}
                            bio={section.bio}
                            initials={section.initials}
                            linkText={section.linkText}
                            linkUrl={section.linkUrl}
                        />
                    )
                case 'bookPreviewSection':
                    return (
                        <BookPreview
                            label={section.label}
                            coverLabel={section.coverLabel}
                            title={section.title}
                            subtitle={section.subtitle}
                            description={section.description}
                            ctaText={section.ctaText}
                            ctaLink={section.ctaLink}
                        />
                    )
                default:
                    return null
            }
        })}
    </main>
</SiteLayout>
