---
import './Footer.scss'

interface NavLink {
    label: string
    href: string
}

interface Props {
    logoTitle?: string
    logoSubtitle?: string
    navLinks: NavLink[]
    description?: string
    topicsTitle?: string
    topics?: NavLink[]
    copyright?: string
    copyrightNote?: string
}

const {
    logoTitle,
    logoSubtitle,
    navLinks,
    description,
    topicsTitle,
    topics = [],
    copyright,
    copyrightNote,
} = Astro.props
---

<footer class='footer'>
    <div class='footer__inner'>
        <div class='footer__brand'>
            <div class='footer__brand-logo'>
                <span class='footer__brand-logo-title'
                    >{logoTitle ?? 'History Reconsidered'}</span
                >
                <span class='footer__brand-logo-subtitle'
                    >{logoSubtitle ?? 'Military History & Research'}</span
                >
            </div>
            {description && (
                <p class='footer__brand-description'>{description}</p>
            )}
        </div>
        <div class='footer__nav-group'>
            <h4 class='footer__nav-title'>Navigate</h4>
            {navLinks.map((link) => (
                <a class='footer__nav-link' href={link.href}>{link.label}</a>
            ))}
        </div>
        {topics.length > 0 && (
            <div class='footer__nav-group'>
                <h4 class='footer__nav-title'>{topicsTitle ?? 'Topics'}</h4>
                {topics.map((topic) => (
                    <a class='footer__nav-link' href={topic.href}>{topic.label}</a>
                ))}
            </div>
        )}
    </div>
    <div class='footer__bottom'>
        <span>{copyright ?? '© 2010–2026 History Reconsidered, LLC'}</span>
        <span>{copyrightNote ?? 'All rights reserved'}</span>
    </div>
</footer>
