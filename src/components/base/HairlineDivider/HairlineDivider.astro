---
import './HairlineDivider.scss'

interface Props {
    width?: 40 | 60
    color?: 'gold' | 'white'
    align?: 'left' | 'center' | 'right'
}

const { width = 40, color = 'gold', align = 'center' } = Astro.props
---

<div
    class={`hairline hairline--${color} hairline--${align}`}
    style={`width: ${width}px`}
></div>
