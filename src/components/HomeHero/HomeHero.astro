---
import Button from '@components/Button/Button.astro'
import Eyebrow from '@components/Eyebrow/Eyebrow.astro'
import HairlineDivider from '@components/HairlineDivider/HairlineDivider.astro'
import './HomeHero.scss'
import type { CTA } from '@app-types/cta'

interface Props {
    label?: string
    title: string
    quote?: string
    quoteAuthor?: string
    imageUrl?: string
    imageAlt?: string
    cta?: CTA
}

const { label, title, quote, quoteAuthor, imageUrl, imageAlt, cta } =
    Astro.props
---

<section class='hero'>
    <div class='hero__bg'>
        {
            imageUrl && (
                <img src={imageUrl} alt={imageAlt ?? ''} class='hero__bg-img' />
            )
        }
    </div>
    <div class='hero__texture'></div>
    <div class='hero__content'>
        {label && <Eyebrow color="gold" size="md" align="center">{label}</Eyebrow>}
        <h1 class='hero__title' set:html={title} />
        <HairlineDivider width={60} color="gold" align="center" />
        {
            quote && (
                <blockquote class='hero__quote'>
                    "{quote}"
                    {quoteAuthor && (
                        <span class='hero__quote-author'>
                            &mdash; {quoteAuthor}
                        </span>
                    )}
                </blockquote>
            )
        }
        {
            cta?.text && (
                <Button
                    variant='outline-gold'
                    size='lg'
                    onTone='dark'
                    href={cta.link ?? '#articles'}
                    text={cta.text}
                    openInNewTab={cta.openInNewTab}
                />
            )
        }
    </div>
    <div class='hero__scroll'></div>
</section>
