---
import Eyebrow from '@components/base/Eyebrow/Eyebrow'
import SectionTitle from '@components/base/SectionTitle/SectionTitle'
import HairlineDivider from '@components/base/HairlineDivider/HairlineDivider'
import './SectionHeader.scss'

interface Props {
    label?: string
    heading?: string
    align?: 'left' | 'center' | 'right'
    tone?: 'light' | 'dark'
}

const { label, heading, align = 'center', tone = 'light' } = Astro.props
---

<div class={`section-header section-header--${align}`}>
    {label && <Eyebrow align={align} color="gold" size="sm">{label}</Eyebrow>}
    {heading && <SectionTitle tone={tone}>{heading}</SectionTitle>}
    <HairlineDivider width={40} color="gold" align={align} />
</div>
