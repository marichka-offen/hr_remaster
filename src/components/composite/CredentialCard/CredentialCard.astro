---
import Star from '@icons/star'
import GraduationCap from '@icons/graduation-cap'
import BookOpen from '@icons/book-open'
import Shield from '@icons/shield'
import Medal from '@icons/medal'
import Pen from '@icons/pen'
import './CredentialCard.scss'

type IconName = 'star' | 'graduation-cap' | 'book-open' | 'shield' | 'medal' | 'pen'

interface Props {
    icon: IconName
    label: string
    title: string
    description?: string
}

const { icon, label, title, description } = Astro.props

const icons: Record<IconName, any> = { star: Star, 'graduation-cap': GraduationCap, 'book-open': BookOpen, shield: Shield, medal: Medal, pen: Pen }
const IconComponent = icons[icon] ?? Star
---

<div class="credential-card">
    <div class="credential-card__icon">
        <IconComponent />
    </div>
    <p class="credential-card__label">{label}</p>
    <h4 class="credential-card__title">{title}</h4>
    {description && <p class="credential-card__description">{description}</p>}
</div>
