---
import Button from '@components/base/Button/Button'
import Eyebrow from '@components/base/Eyebrow/Eyebrow'
import PlaceholderImage from '@components/base/PlaceholderImage/PlaceholderImage'
import CoverFrame from '@components/composite/CoverFrame/CoverFrame.astro'
import './AboutPreview.scss'
import type { CTA } from '@app-types/cta'

interface Props {
    name: string
    role?: string
    bio?: any[]
    imageUrl?: string
    imageAlt?: string
    initials?: string
    cta?: CTA
}

const { name, role, bio, imageUrl, imageAlt, initials, cta } = Astro.props
---

<section class="about-preview">
    <div class="about-preview__container">
        <div class="about-preview__grid">
            <CoverFrame inset={8} class="about-preview__image">
                {imageUrl ? (
                    <img src={imageUrl} alt={imageAlt ?? name} class="about-preview__portrait" />
                ) : (
                    <PlaceholderImage
                        gradient="linear-gradient(135deg, var(--navy) 0%, var(--burgundy) 100%)"
                        code={initials ?? ''}
                        aspect="portrait"
                    />
                )}
            </CoverFrame>
            <div class="about-preview__text">
                <h3 class="about-preview__name">{name}</h3>
                {role && <Eyebrow color="gold" size="sm" align="left">{role}</Eyebrow>}
                {bio?.map((block: any) => {
                    if (block._type === 'block') {
                        const text = block.children?.map((c: any) => c.text).join('') ?? ''
                        return <p>{text}</p>
                    }
                })}
                {cta?.text && (
                    <Button
                        variant='text'
                        onTone='light'
                        href={cta.link ?? '/about'}
                        text={cta.text}
                        openInNewTab={cta.openInNewTab}
                    />
                )}
            </div>
        </div>
    </div>
</section>
