---
import Button from '@components/base/Button/Button'
import Eyebrow from '@components/base/Eyebrow/Eyebrow'
import HairlineDivider from '@components/base/HairlineDivider/HairlineDivider'
import QuoteBlock from '@components/composite/QuoteBlock/QuoteBlock.astro'
import './HomeHero.scss'
import type { CTA } from '@app-types/cta'

interface Props {
    label?: string
    title: string
    quote?: string
    quoteAuthor?: string
    imageUrl?: string
    imageAlt?: string
    cta?: CTA
}

const { label, title, quote, quoteAuthor, imageUrl, imageAlt, cta } =
    Astro.props
---

<section class='hero'>
    <div class='hero__bg'>
        {
            imageUrl && (
                <img src={imageUrl} alt={imageAlt ?? ''} class='hero__bg-img' />
            )
        }
    </div>
    <div class='hero__texture'></div>
    <div class='hero__content'>
        {label && <Eyebrow color="gold" size="md" align="center">{label}</Eyebrow>}
        <h1 class='hero__title' set:html={title} />
        <HairlineDivider width={60} color="gold" align="center" />
        {quote && <QuoteBlock quote={quote} author={quoteAuthor} tone="dark" />}
        {
            cta?.text && (
                <Button
                    variant='outline-gold'
                    size='lg'
                    onTone='dark'
                    href={cta.link ?? '#articles'}
                    text={cta.text}
                    openInNewTab={cta.openInNewTab}
                />
            )
        }
    </div>
    <div class='hero__scroll'></div>
</section>
