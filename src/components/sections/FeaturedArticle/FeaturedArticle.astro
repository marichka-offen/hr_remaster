---
import Button from '@components/base/Button/Button.astro'
import Eyebrow from '@components/base/Eyebrow/Eyebrow.astro'
import SectionHeader from '@components/composite/SectionHeader/SectionHeader.astro'
import PlaceholderImage from '@components/base/PlaceholderImage/PlaceholderImage.astro'
import CategoryChip from '@components/base/CategoryChip/CategoryChip.astro'
import ArticleMeta from '@components/base/ArticleMeta/ArticleMeta.astro'
import './FeaturedArticle.scss'
import type { ArticleMeta as ArticleMetaType } from '@app-types/article'

interface Props {
    label?: string
    heading?: string
    article: ArticleMetaType
}

const { label, heading, article } = Astro.props
const articleUrl = `/articles/${article.slug}`
const tagLine = article.subtitle
const gradient = article.gradientFrom && article.gradientTo
    ? `linear-gradient(135deg, ${article.gradientFrom} 0%, ${article.gradientTo} 100%)`
    : 'linear-gradient(135deg, var(--navy-light) 0%, var(--burgundy) 100%)'
const code = article.period ?? ''
const overlayCategory = article.tags ? article.tags[0] : 'Featured Article'
---

<section class='featured'>
    <div class='featured__container'>
        <div class='featured__header'>
            <SectionHeader label={label} heading={heading} align="center" />
        </div>

        <div class='featured__card'>
            <div class='featured__image'>
                {article.imageUrl ? (
                    <img src={article.imageUrl} alt={article.imageAlt ?? article.title} class='featured__image-img' />
                ) : (
                    <PlaceholderImage gradient={gradient} code={code} aspect="landscape" />
                )}
                <div class='featured__image-overlay'>
                    <CategoryChip label={overlayCategory} variant="overlay" />
                </div>
            </div>
            <div class='featured__body'>
                {tagLine && <Eyebrow color="gold" size="sm" align="left">{tagLine}</Eyebrow>}
                <h3 class='featured__title'>{article.title}</h3>
                {
                    article.excerpt && (
                        <p class='featured__excerpt'>{article.excerpt}</p>
                    )
                }
                <div class='featured__meta'>
                    <ArticleMeta readTime={article.readTime} tag={article.tags?.[0]} tone="dark" />
                </div>
                <Button
                    variant='text'
                    onTone='dark'
                    href={articleUrl}
                    text='Read Article'
                />
            </div>
        </div>
    </div>
</section>
