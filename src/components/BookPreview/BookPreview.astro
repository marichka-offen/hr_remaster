---
import './BookPreview.scss'
---

<section class="book-preview">
    <div class="book-preview__container">
        <div class="book-preview__inner">
            <div class="book-preview__cover">
                <div class="book-preview__cover-label">Forthcoming</div>
                <div class="book-preview__cover-title">None Shall Pass Us by in Silence</div>
                <div class="book-preview__cover-author">The Czechoslovak Legion, 1914&ndash;1920</div>
            </div>
            <div class="book-preview__info">
                <div class="book-preview__info-label">Upcoming Book</div>
                <h3>None Shall Pass Us by in Silence</h3>
                <p>
                    The full story of the Czechoslovak Legion &mdash; a military
                    formation that fought across 4,000 miles of Russia, captured the
                    imagination of Allied nations, and earned nationhood for the
                    Czechoslovak people.
                </p>
                <a href="/book" class="book-preview__cta">Learn More</a>
            </div>
        </div>
    </div>
</section>
