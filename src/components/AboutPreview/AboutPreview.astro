<section class="about-preview">
    <div class="about-preview__container">
        <div class="about-preview__grid">
            <div class="about-preview__image">
                <span class="about-preview__initials">LO</span>
            </div>
            <div class="about-preview__text">
                <h3 class="about-preview__name">Lee Offen</h3>
                <span class="about-preview__role">Military Historian &amp; Retired Soldier</span>
