---
import './AboutPreview.scss'
import type { CTA } from '@app-types/cta'

interface Props {
    name: string
    role?: string
    bio?: any[]
    imageUrl?: string
    imageAlt?: string
    initials?: string
    cta?: CTA
}

const { name, role, bio, imageUrl, imageAlt, initials, cta } = Astro.props
---

<section class="about-preview">
    <div class="about-preview__container">
        <div class="about-preview__grid">
            <div class="about-preview__image">
                {imageUrl ? (
                    <img src={imageUrl} alt={imageAlt ?? name} class="about-preview__portrait" />
                ) : (
                    <span class="about-preview__initials">{initials ?? ''}</span>
                )}
            </div>
            <div class="about-preview__text">
                <h3 class="about-preview__name">{name}</h3>
                {role && <span class="about-preview__role">{role}</span>}
                {bio?.map((block: any) => {
                    if (block._type === 'block') {
                        const text = block.children?.map((c: any) => c.text).join('') ?? ''
                        return <p>{text}</p>
                    }
                })}
                {cta?.text && (
                    <a href={cta.link ?? '/about'} class="about-preview__link" {...(cta.openInNewTab && { target: '_blank', rel: 'noopener noreferrer' })}>
                        {cta.text}
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                    </a>
                )}
            </div>
        </div>
    </div>
</section>
